# Copy to .env and fill in values.
# Run: cp .env.example .env

# Async URL for FastAPI (uvicorn process)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5434/resume_service

# Sync URL for Celery (worker process)
# Same host/db, different driver prefix
CELERY_DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5434/resume_service

REDIS_URL=redis://localhost:6379/0

APP_ENV=development
DEBUG=true
